# Public canonical URL used for metadata, sitemap, and social sharing.
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Optional: increases GitHub API limits. Never prefix this with NEXT_PUBLIC_.
GITHUB_TOKEN=

# Optional: a trusted JSON endpoint returning a programming quote.
# The site defaults to its curated local quote collection.
QUOTE_API_URL=

# Enables automatic contact-form delivery to abramishvililasha05@gmail.com.
# Keep this secret and configure it only in .env.local or your hosting dashboard.
RESEND_API_KEY=

# Optional. The default test sender works when the Resend account belongs to
# abramishvililasha05@gmail.com. Use a verified domain sender for production branding.
CONTACT_FROM_EMAIL=Lasha Abramishvili <onboarding@resend.dev>
