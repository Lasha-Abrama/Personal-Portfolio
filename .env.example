# Public canonical URL used for metadata, sitemap, and social sharing.
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Optional: increases GitHub API limits. Never prefix this with NEXT_PUBLIC_.
GITHUB_TOKEN=

# Optional: a trusted JSON endpoint returning a programming quote.
# The site defaults to its curated local quote collection.
QUOTE_API_URL=

# Optional contact delivery via Resend. Without these, the form creates a mailto draft.
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=Portfolio <hello@your-verified-domain.example>

